<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.canvas.*?>

<StackPane xmlns="http://javafx.com/javafx"
           xmlns:fx="http://javafx.com/fxml"
           fx:controller="ui.controller.MapController"
           styleClass="map-pane">

    <!--
        Canvas 500x500 - khớp đúng kích thước bản đồ.
        Zoom/pan được xử lý bằng ZoomManager trong MapController,
        KHÔNG dùng transform của JavaFX để giữ kiểm soát tọa độ.
    -->
    <Canvas fx:id="mapCanvas" width="500" height="500"/>

</StackPane>
